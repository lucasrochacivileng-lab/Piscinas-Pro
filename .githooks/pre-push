#!/bin/sh
# Impede o envio de commits que nao passam na checagem TypeScript.
#
# Em repositorios hospedados em drives sincronizados (Google Drive) o npm falha
# com EBADF ao escrever node_modules. Nesse caso a checagem roda sobre uma copia
# do commit fora do drive, no mesmo padrao de scripts/verify-local.ps1.
#
# Use SKIP_PREPUSH_CHECK=1 git push para pular a checagem em uma emergencia.

set -u

if [ "${SKIP_PREPUSH_CHECK:-}" = "1" ]; then
  echo "pre-push: checagem pulada por SKIP_PREPUSH_CHECK=1" >&2
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

fail() {
  echo "" >&2
  echo "pre-push: a checagem TypeScript falhou; push cancelado." >&2
  echo "pre-push: corrija os erros acima ou use SKIP_PREPUSH_CHECK=1 git push." >&2
  exit 1
}

# Caminho rapido: o proprio repositorio consegue rodar o npm.
if [ -x node_modules/.bin/tsc ]; then
  echo "pre-push: rodando npm run check"
  npm run check || fail
  exit 0
fi

# Caminho espelhado: valida o commit em uma pasta fora do drive sincronizado.
base=${LOCALAPPDATA:-${TMPDIR:-/tmp}}
work="$base/poolstruct/prepush"
mirror="$work/tree"

echo "pre-push: node_modules indisponivel aqui; validando em $mirror"
rm -rf "$mirror" || fail
mkdir -p "$mirror" || fail
git archive HEAD | tar -x -C "$mirror" || fail

echo "pre-push: instalando dependencias na copia limpa"
(cd "$mirror" && npm ci --no-audit --no-fund) || fail

(cd "$mirror" && npm run check) || fail
